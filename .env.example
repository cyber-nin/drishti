# ========================================
# Drishti OSINT Platform - Configuration
# ========================================
# Copy this file to .env and update values

# ===== API Keys =====
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
GROQ_API_KEY=your_groq_api_key_here
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# ===== Enrichment API Keys =====
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ===== Search Configuration =====
# Cooldown period (in minutes) before retrying failed search engines
SEARCH_ENGINE_COOLDOWN_MINUTES=5

# Number of consecutive failures before marking engine as down
SEARCH_ENGINE_MAX_FAILURES=3

# HTTP request timeout for search queries (in seconds)
SEARCH_REQUEST_TIMEOUT=30

# Maximum number of search results to return
SEARCH_RESULT_LIMIT=50

# ===== Scraping Configuration =====
# HTTP request timeout for web scraping (in seconds)
SCRAPE_REQUEST_TIMEOUT=30

# Number of concurrent scraping workers
SCRAPE_MAX_WORKERS=5

# Maximum characters to extract from each scraped page
SCRAPE_MAX_CHARS=50000

# ===== Deep Crawl Configuration =====
# Maximum depth for recursive crawling (default: 2)
CRAWL_MAX_DEPTH=2

# Maximum number of pages to crawl (default: 20)
CRAWL_MAX_PAGES=20

# HTTP request timeout for crawling (in seconds)
CRAWL_REQUEST_TIMEOUT=10

# ===== Artifact Extraction Configuration =====
# Context window size for artifact extraction (words)
ARTIFACT_CONTEXT_WINDOW=50

# Enable deduplication of artifacts (true/false)
ARTIFACT_DEDUP_ENABLED=true

# ===== LLM Configuration =====
# Enable LLM response caching (true/false)
LLM_CACHE_ENABLED=true

# Maximum cache size for LLM responses
LLM_CACHE_MAX_SIZE=1000

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.0

# Enable streaming responses (true/false)
LLM_STREAMING_ENABLED=true

# ===== Flask Configuration =====
# Enable Flask debug mode (true/false) - DO NOT USE IN PRODUCTION
FLASK_DEBUG=false

# Flask server port
FLASK_PORT=5000

# Flask server host (0.0.0.0 = exposed, 127.0.0.1 = localhost only)
FLASK_HOST=0.0.0.0

# ===== Logging Configuration =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/drishti.log

# ===== Proxy Configuration =====
# Tor proxy host
TOR_PROXY_HOST=127.0.0.1

# Tor proxy port (default SOCKS5: 9050)
TOR_PROXY_PORT=9050

# Tor control port (for circuit rotation)
TOR_CONTROL_PORT=9051

# Tor control password (if configured)
TOR_CONTROL_PASSWORD=

# ===== Output Configuration =====
# Directory for saving investigation reports
OUTPUT_DIR=outputs

# Report format: markdown, json, csv
REPORT_FORMAT=markdown

# ===== Feature Flags =====
# Enable deep crawling feature (true/false)
ENABLE_DEEP_CRAWL=true

# Enable automatic artifact extraction (true/false)
ENABLE_ARTIFACT_EXTRACTION=true

# Enable response caching (true/false)
ENABLE_CACHING=true
